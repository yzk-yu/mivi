# 觅 MIVI 后端环境变量 —— 复制本文件为 .env 并填入自己的 key
# 密钥绝不提交到 git，绝不写进代码

# 总开关：true=全程Mock(演示最稳)  false=走真实接口
MIVI_USE_MOCK=false

# 高德 Web 服务 key（POI/路径/天气/地理编码）
AMAP_API_KEY=你的高德key

# LLM 选哪家：deepseek（默认） | kimi | qwen
MIVI_LLM_PROVIDER=deepseek

# 对应所选 LLM 的 key（填你在用的那家即可）
DEEPSEEK_API_KEY=你的deepseek-key
# KIMI_API_KEY=你的moonshot-key
# DASHSCOPE_API_KEY=你的通义key

# 可选：覆盖默认模型名
# DEEPSEEK_MODEL=deepseek-v4-flash
